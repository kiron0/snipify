{
  "name": "snipify",
  "description": "A CLI tool for capturing and processing web screenshots with Puppeteer and Sharp.",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "snipify": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run tests/cli.test.ts tests/live-e2e.test.ts",
    "test:build": "vitest run tests/build.test.ts",
    "test:pack": "vitest run tests/tarball.test.ts",
    "test:smoke": "npm run build && node dist/index.js --help",
    "test:e2e:live": "vitest run tests/live-e2e.test.ts",
    "build:watch": "tsup --watch",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "author": "Toufiq Hasan Kiron <hello@kiron.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiron0/snipify"
  },
  "bugs": {
    "url": "https://github.com/kiron0/snipify/issues"
  },
  "homepage": "https://snipify.js.org",
  "keywords": [
    "cli",
    "screenshot",
    "puppeteer",
    "web-capture",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
